---
/**
 * Footer — placeholder for Phase 1.
 *
 * Phase 2 ports the real marketing footer (links, social, license).
 * Kept minimal but presentable so the placeholder pages don't end abruptly.
 */
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-white/5 bg-slate-950/40">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-6 py-8 text-xs text-slate-500 sm:flex-row">
    <p>
      &copy; {year} Atomic Spec. Released under the MIT License.
    </p>
    <p class="font-mono uppercase tracking-widest text-xs text-slate-400">
      Phase 1 scaffold
    </p>
  </div>
</footer>
