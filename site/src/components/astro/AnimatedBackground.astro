---
/**
 * AnimatedBackground — drifting, blurred gradient blobs + faint fractal-noise.
 * Sits behind everything (`-z-50`), `pointer-events-none`, `aria-hidden`.
 *
 * Performance notes (post-audit):
 *   - Each blob is a `blur(80px)` rectangle on a 50vw element. On a 390x844 phone
 *     at DPR 3 that's ~12 MB of GPU compositor memory PER blob. With three blobs
 *     animating continuously, weak Androids start sweating.
 *   - Mitigations:
 *       1. Mobile (`max-width: 768px`): drop the third blob, halve the blur,
 *          freeze the animation, drop the noise overlay. Cuts GPU work ~70%.
 *       2. `prefers-reduced-motion`: animation collapses via global.css rule.
 *       3. `document.hidden`: pause animation when tab is backgrounded so it
 *          doesn't drain battery while you're in another tab.
 */
---

<div
  class="animated-bg fixed inset-0 -z-50 overflow-hidden pointer-events-none"
  aria-hidden="true"
>
  <div class="blob blob--emerald"></div>
  <div class="blob blob--blue"></div>
  <!-- Third blob is desktop-only; it pushes mobile GPU budget too far. -->
  <div class="blob blob--indigo desktop-only"></div>

  <!-- Subtle fractal-noise overlay (desktop only — mobile drops it entirely). -->
  <svg class="noise desktop-only" xmlns="http://www.w3.org/2000/svg">
    <filter id="noise">
      <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="3" stitchTiles="stitch" />
      <feColorMatrix type="saturate" values="0" />
    </filter>
    <rect width="100%" height="100%" filter="url(#noise)" />
  </svg>
</div>

<script>
  // Pause the blob animations whenever the tab is hidden. Saves battery /
  // wakeups on mobile and prevents GPU work for windows the user isn't looking
  // at. Re-resumes on visibilitychange. No-op on devices that don't honor it.
  function syncBackgroundPlayState(): void {
    const root = document.querySelector<HTMLElement>('.animated-bg');
    if (!root) return;
    root.style.setProperty(
      '--bg-play-state',
      document.hidden ? 'paused' : 'running',
    );
  }
  document.addEventListener('visibilitychange', syncBackgroundPlayState);
  syncBackgroundPlayState();
</script>

<style>
  /* Blobs use `screen` (additive) so they brighten the slate-950 surface;
     `overlay` collapses to dark against near-black backgrounds. */
  .blob {
    position: absolute;
    width: clamp(40vw, 50vmax, 80vw);
    height: clamp(40vw, 50vmax, 80vw);
    border-radius: 9999px;
    filter: blur(80px);
    opacity: 0.45;
    mix-blend-mode: screen;
    will-change: transform;
    /* Animation play-state is driven by the visibilitychange handler above
       via the --bg-play-state CSS var. */
    animation-play-state: var(--bg-play-state, running);
  }

  .blob--emerald {
    top: -10vw;
    left: -10vw;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.55), transparent 70%);
    animation: drift1 19s infinite ease-in-out alternate;
  }

  .blob--blue {
    top: -15vw;
    right: -15vw;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.5), transparent 70%);
    animation: drift2 29s infinite ease-in-out alternate;
  }

  .blob--indigo {
    bottom: -20vw;
    left: 25vw;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.55), transparent 70%);
    animation: drift3 41s infinite ease-in-out alternate;
  }

  .noise {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.05;
    mix-blend-mode: soft-light;
  }

  /* Mobile: drop the third blob, drop the noise filter, halve the blur,
     freeze the animation. The blobs become static gradient washes — visually
     close enough, GPU work down ~70%. */
  @media (max-width: 768px) {
    .desktop-only {
      display: none;
    }

    .blob {
      filter: blur(40px);
      opacity: 0.3;
      animation: none;
      transform: none;
    }
  }

  @keyframes drift1 {
    from { transform: translate3d(-8%, -6%, 0) scale(1);    }
    to   { transform: translate3d( 8%,  6%, 0) scale(1.15); }
  }

  @keyframes drift2 {
    from { transform: translate3d( 10%, -12%, 0) scale(1.1); }
    to   { transform: translate3d(-10%,  12%, 0) scale(0.95);}
  }

  @keyframes drift3 {
    from { transform: translate3d( 0%,  8%, 0) scale(1);    }
    to   { transform: translate3d(-12%, -8%, 0) scale(1.2); }
  }
</style>
