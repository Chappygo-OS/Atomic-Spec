---
/**
 * Solution — the three pillars of the Atomic Traceability Model.
 *
 * Static Astro. Boss's component used `motion.div` with `whileHover={{ y: -5 }}`;
 * we replace that with Tailwind `hover:-translate-y-1` so the card still lifts
 * but we don't ship Framer Motion for a hover lift.
 *
 * Pillars come from the README and Article IX of the constitution:
 *   1. Constitutional governance (eight Prime Directives + Project Defaults Registry)
 *   2. HITL checkpoints (the four gates: Tech Stack, Validation, UI, Registry sync)
 *   3. Atomic task decomposition (Atomic Injunction → tasks/T-XXX-*.md)
 */
import { Icon } from 'astro-icon/components';

interface Pillar {
  icon: string;
  title: string;
  body: string;
  bullets: string[];
}

const pillars: Pillar[] = [
  {
    icon: 'lucide:scale',
    title: 'Constitutional governance',
    body:
      'Every AI decision is bound by a constitution. Article IX hardcodes the eight Prime Directives — non-negotiable rules every command enforces.',
    bullets: [
      'Consistency across features',
      'Eight immutable Prime Directives',
      'Project Defaults Registry as source of truth',
    ],
  },
  {
    icon: 'lucide:users',
    title: 'HITL checkpoints',
    body:
      'The AI proposes. Humans approve. At four critical decision points, the system STOPS until you sign off.',
    bullets: [
      'No silent assumptions',
      'Tech stack review',
      'Validation review',
      'UI/UX approval',
      'Registry sync',
    ],
  },
  {
    icon: 'lucide:file-code',
    title: 'Atomic task decomposition',
    body:
      'Instead of one monolithic tasks.md, every feature explodes into isolated T-XXX files. The agent reads only the current task — by design.',
    bullets: [
      'One requirement per file',
      'Embedded context (registry + domain rules + gate criteria)',
      'Verification command included',
      'Context Pinning during implementation',
    ],
  },
];
---

<section id="solution" class="relative overflow-hidden bg-transparent py-24">
  {/* Decorative blob — kept subtle since AnimatedBackground already supplies atmosphere. */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute right-0 top-0 h-[500px] w-[500px] rounded-full bg-emerald-500/5 blur-3xl"
  >
  </div>

  <div class="container relative z-10 mx-auto px-4">
    <div class="mb-16 text-center">
      <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-emerald-400">
        The Solution
      </p>
      <h2 class="text-3xl font-bold text-white md:text-4xl">The Atomic Traceability Model</h2>
      <p class="mx-auto mt-4 max-w-2xl text-slate-400">
        A governance framework that turns the AI from an unpredictable collaborator into a
        system that ships consistent, traceable code — feature after feature.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-3">
      {
        pillars.map((p) => (
          <article class="rounded-2xl border border-slate-800 bg-slate-950/60 p-8 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:border-emerald-500/30">
            <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-slate-900 text-emerald-400">
              <Icon name={p.icon} class="h-8 w-8" />
            </div>
            <h3 class="mb-4 text-xl font-bold text-white">{p.title}</h3>
            <p class="mb-4 text-slate-400">{p.body}</p>
            <ul class="space-y-2 text-sm text-slate-400">
              {p.bullets.map((b) => (
                <li class="flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-500" aria-hidden="true" />
                  {b}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
