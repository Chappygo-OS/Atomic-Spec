---
/**
 * /docs — documentation landing.
 *
 * Renders a category-grouped card index sourced from the `docs`
 * collection. The Phase 1 placeholder is gone; this is the live
 * landing page from Phase 3 forward.
 *
 * Each card shows the doc title, description, and a "Read →" affordance.
 * Cards keep visual continuity with the rest of the site (slate panels,
 * emerald hover accent, no clichéd gradient borders).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDocsNav } from '../../lib/nav';
import { withBase } from '../../lib/url';

const nav = await getDocsNav();
const docsCount = nav.reduce((acc, group) => acc + group.items.length, 0);
const githubRepo = 'https://github.com/Chappygo-OS/Atomic-Spec';
---

<BaseLayout
  title="Documentation — Atomic Spec"
  description="Atomic Spec documentation: installation, quick start, governance concepts, and contribution guides for the Atomic Traceability Model."
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <header class="mb-14 max-w-3xl">
      <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-emerald-300">
        Documentation
      </p>
      <h1 class="mt-3 text-balance text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Everything you need to install, run, and extend Atomic Spec.
      </h1>
      <p class="mt-5 text-pretty text-lg leading-relaxed text-slate-300">
        {docsCount} guides covering installation, the four-phase assembly line,
        the Eight Prime Directives, and how to contribute back to the framework.
        Start with <a href={withBase('/docs/installation')} class="text-emerald-300 underline-offset-4 transition hover:underline">Installation</a>
        if you're new, or jump straight to <a href={withBase('/docs/quickstart')} class="text-emerald-300 underline-offset-4 transition hover:underline">Quick Start</a>
        if you've already got the CLI.
      </p>
    </header>

    {
      nav.map((group) => (
        <section class="mb-14 last:mb-0" aria-labelledby={`group-${group.category.replace(/\s+/g, '-').toLowerCase()}`}>
          <h2
            id={`group-${group.category.replace(/\s+/g, '-').toLowerCase()}`}
            class="mb-6 flex items-baseline gap-3 border-b border-slate-800 pb-2"
          >
            <span class="text-xs font-bold uppercase tracking-[0.18em] text-emerald-400">
              {group.category}
            </span>
            <span class="text-xs font-medium text-slate-500">
              {group.items.length} {group.items.length === 1 ? 'doc' : 'docs'}
            </span>
          </h2>
          <ul class="grid gap-4 sm:grid-cols-2">
            {group.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="group flex h-full flex-col rounded-xl border border-slate-800 bg-slate-900/40 p-5 transition hover:border-emerald-500/40 hover:bg-slate-900/70"
                >
                  <h3 class="text-base font-semibold text-white">{item.title}</h3>
                  <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-400">
                    {item.description}
                  </p>
                  <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-emerald-400 transition group-hover:gap-1.5">
                    Read
                    <span aria-hidden="true">→</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }

    <p class="mt-16 text-sm text-slate-500">
      Spotted something out of date?{' '}
      <a
        href={`${githubRepo}/tree/main/site/src/content/docs`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-emerald-300 underline-offset-4 transition hover:underline"
      >
        Open a PR
      </a>{' '}
      against the source MDX — the site rebuilds on merge.
    </p>
  </section>
</BaseLayout>
