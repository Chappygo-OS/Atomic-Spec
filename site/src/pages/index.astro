---
/**
 * Home page — Phase 2 marketing landing.
 *
 * Composition order matches COPY.md (locked 2026-04-29):
 *   Hero → Problem → Solution → Manual → Agents → HITL → ContextPinning → Workflow → Footer
 *
 * Hydration strategy:
 *   - Hero          client:load     (above-the-fold typewriter + tilt)
 *   - Problem       static
 *   - Solution      static
 *   - Manual        client:idle     (far below fold; static HTML reads fine pre-hydration)
 *   - Agents        static
 *   - HITL          client:visible
 *   - ContextPinning client:visible
 *   - Workflow      static
 *   - Footer        static (rendered by BaseLayout)
 *
 * BaseLayout already renders the AnimatedBackground, header, and Footer — we
 * just slot the page-specific sections in between.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/react/Hero.tsx';
import Problem from '../components/astro/Problem.astro';
import Solution from '../components/astro/Solution.astro';
import Manual from '../components/react/Manual.tsx';
import Agents from '../components/astro/Agents.astro';
import HITL from '../components/react/HITL.tsx';
import ContextPinning from '../components/react/ContextPinning.tsx';
import Workflow from '../components/astro/Workflow.astro';
---

<BaseLayout
  title="Atomic Spec — Precision engineering for AI-written code"
  description="A governance framework that turns unpredictable AI into a governed assembly line — eight Prime Directives, four HITL checkpoints, atomic task files, and 21 specialized subagents."
>
  <Hero client:load />
  <Problem />
  <Solution />
  <Manual client:idle />
  <Agents />
  <HITL client:visible />
  <ContextPinning client:visible />
  <Workflow />
</BaseLayout>
