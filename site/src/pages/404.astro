---
/**
 * 404 — branded not-found page. Same shell as index.astro so the broken-link
 * experience still feels like the rest of the site.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/url';

const home = withBase('/');
---

<BaseLayout
  title="404 — Atomic Spec"
  description="The page you were looking for doesn't exist on the Atomic Spec site."
>
  <section class="relative isolate">
    <div
      aria-hidden="true"
      class="bg-grid pointer-events-none absolute inset-0 opacity-25
             [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]"
    ></div>

    <div class="relative mx-auto flex min-h-[70vh] max-w-3xl flex-col items-center justify-center px-6 py-24 text-center">
      <p class="font-mono text-[11px] uppercase tracking-[0.25em] text-emerald-300">
        Error 404
      </p>

      <h1 class="mt-3 bg-gradient-to-b from-white via-slate-100 to-slate-500 bg-clip-text text-7xl font-semibold tracking-tight text-transparent sm:text-8xl">
        Drifted off-path
      </h1>

      <p class="mt-5 max-w-xl text-pretty text-base text-slate-300 sm:text-lg">
        That page doesn't exist — either it never did, or it hasn't shipped yet.
        Either way, the Eight Prime Directives are still intact.
      </p>

      <a
        href={home}
        class="mt-10 inline-flex items-center gap-2 rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-slate-950 shadow-[0_10px_40px_-10px_rgba(16,185,129,0.7)] transition hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
      >
        <span aria-hidden="true">&larr;</span>
        Back to home
      </a>
    </div>
  </section>
</BaseLayout>
